{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "tab",
    "indentWidth": 4
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "off",
      "complexity": {
        "noExcessiveCognitiveComplexity": "error",
        "noExcessiveNestedTestSuites": "error"
      },
      "correctness": {
        "noUndeclaredVariables": "error",
        "noUndeclaredDependencies": "error"
      },
      "style": {
        "noCommonJs": "error",
        "noMagicNumbers": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "lineEnding": "crlf"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "recommended": true
    }
  }
}
