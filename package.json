{
  "name": "dt-clamps",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Declarative deployment controller for configuring cloud resources and services from YAML using Bun and TypeScript.",
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "check": "bunx tsc --noEmit",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write .",
    "test": "bun test"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.2.2",
    "typescript": "^5.7.2"
  }
}
